{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JoystickOwerlayInstallManifest",
  "type": "object",
  "required": ["manifest_version", "product_id", "display_name", "install_mode", "install_root"],
  "properties": {
    "manifest_version": { "type": "integer", "const": 1 },
    "product_id": { "type": "string" },
    "display_name": { "type": "string" },
    "install_mode": { "enum": ["installed", "portable"] },
    "install_root": { "type": "string" },
    "data_root": { "type": "string" },
    "data_root_relative": { "type": ["string", "null"] },
    "runtime": { "type": "object" },
    "shortcuts": { "type": "array" },
    "registry": { "type": "object" },
    "migration": { "type": "object" },
    "options": { "type": "object" },
    "installed_at": { "type": "string" },
    "installed_by_setup_version": { "type": "string" }
  }
}
